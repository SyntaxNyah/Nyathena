{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SC",
  "type": "object",
  "properties": {
    "$header": {
      "type": "string",
      "const": "SC"
    },
    "char_data": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "desc": {
            "type": "string",
            "default": ""
          },
          "evidence": {
            "type": "string",
            "default": ""
          }
        },
        "required": [
          "name"
        ],
        "additionalProperties": false
      }
    }
  },
  "required": [
    "$header",
    "char_data"
  ],
  "additionalProperties": false
}
